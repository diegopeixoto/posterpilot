# --- Plex ---
PLEX_URL=http://localhost:32400
PLEX_TOKEN=

# --- TMDB --- (v3 API key OR v4 bearer/JWT — auto-detected)
TMDB_KEY=

# --- Kometa --- output dir for exported YAML (a mounted volume in Docker)
KOMETA_ASSETS_DIR=./data/kometa

# --- Kometa manager (optional) --- manage Kometa's OWN config.yml.
# Leave KOMETA_CONFIG_PATH blank to keep this feature OFF. When set, point it at
# Kometa's config.yml (mount that dir in Docker). PosterPilot writes posterpilot.yml
# into the SAME directory as config.yml (co-located) and wires it in by its bare
# basename, so there is no separate metadata path or mount. KOMETA_CONFIG_MODE is
# `merge` (default, surgical) or `own` (PosterPilot owns/regenerates the whole file).
# Both can also be set on the dedicated /kometa manager page in the app.
KOMETA_CONFIG_PATH=
KOMETA_CONFIG_MODE=

# --- Database --- libsql file URL
DATABASE_URL=file:./data/posterpilot.db

# --- Server ---
PORT=3000

# --- Scraping --- politeness + caching
MEDIUX_REQUEST_DELAY_MS=2000
MEDIUX_CONCURRENCY=5
HTTP_CACHE_TTL_DAYS=7
