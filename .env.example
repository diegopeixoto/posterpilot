# --- Plex ---
PLEX_URL=http://localhost:32400
PLEX_TOKEN=

# --- TMDB --- (v3 API key OR v4 bearer/JWT — auto-detected)
TMDB_KEY=

# --- Kometa --- output dir for exported YAML (a mounted volume in Docker)
KOMETA_ASSETS_DIR=./data/kometa

# --- Kometa config sync (optional) --- manage Kometa's OWN config.yml.
# Leave KOMETA_CONFIG_PATH blank to keep this feature OFF. When set, point it at
# Kometa's config.yml (mount that dir in Docker). KOMETA_METADATA_PATH is the path
# Kometa sees for posterpilot.yml (defaults to KOMETA_ASSETS_DIR — override only on
# split mounts). KOMETA_CONFIG_MODE is `merge` (default, surgical) or `own`
# (PosterPilot owns/regenerates the whole file). Leave both blank to use defaults;
# all three can also be set in the Settings → Kometa config tab instead.
KOMETA_CONFIG_PATH=
KOMETA_METADATA_PATH=
KOMETA_CONFIG_MODE=

# --- Database --- libsql file URL
DATABASE_URL=file:./data/posterpilot.db

# --- Server ---
PORT=3000

# --- Scraping --- politeness + caching
MEDIUX_REQUEST_DELAY_MS=2000
MEDIUX_CONCURRENCY=5
HTTP_CACHE_TTL_DAYS=7
